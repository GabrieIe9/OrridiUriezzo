# Required: server-only key. Never prefix this variable with NEXT_PUBLIC_.
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional: defaults to the multilingual example voice used by ElevenLabs docs.
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Public canonical URL used by metadata and the printable QR code.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
