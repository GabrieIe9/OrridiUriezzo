# Server-only secrets. Never use NEXT_PUBLIC_ for these keys.
GEMINI_API_KEY=replace_with_a_new_gemini_key
GEMINI_MODEL=gemini-2.5-flash

ELEVENLABS_API_KEY=replace_with_a_new_elevenlabs_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Canonical origin and Italian share URL.
NEXT_PUBLIC_SITE_URL=https://orridiuriezzo.vercel.app
NEXT_PUBLIC_SHARE_URL=https://orridiuriezzo.vercel.app/it

# Vercel automatically sends this value as a Bearer token to the cron route.
CRON_SECRET=replace_with_a_random_string_of_at_least_16_characters

# Blob authentication is created automatically when a Blob store is connected.
# Do not commit real values. Vercel provides BLOB_STORE_ID and VERCEL_OIDC_TOKEN.
# BLOB_STORE_ID=store_xxx
# VERCEL_OIDC_TOKEN=managed_by_vercel
# Optional legacy/local alternative:
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
